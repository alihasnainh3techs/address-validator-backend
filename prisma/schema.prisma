generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model addressvalidationrule {
  id                               Int      @id @default(autoincrement())
  shop                             String   @unique(map: "AddressValidationRule_shop_key")
  min_char_length                  Int      @default(20)
  min_word_count                   Int      @default(4)
  structural_keywords              String   @db.LongText
  min_structural_keywords_required Int      @default(2)
  landmark_keywords                String   @db.LongText
  min_landmarks_required           Int      @default(1)
  require_house_number             Boolean  @default(true)
  require_landmark_if_no_number    Boolean  @default(true)
  max_failed_checks                Int      @default(2)
  created_at                       DateTime @default(now())
  updated_at                       DateTime @default(now())
}

model order {
  id               Int                  @id @default(autoincrement())
  shop             String
  retry_count      Int                  @default(0)
  order_id         String
  name             String
  customer         String
  address_status   order_address_status @default(COMPLETE)
  failed_rules     String?              @db.LongText
  created_at       DateTime             @default(now())
  updated_at       DateTime
  orderaddresslink orderaddresslink[]

  @@unique([shop, order_id], map: "Order_shop_order_id_key")
  @@index([shop], map: "Order_shop_idx")
}

model orderaddresslink {
  id         Int       @id @default(autoincrement())
  order_id   Int
  token      String    @unique(map: "OrderAddressLink_token_key")
  used_at    DateTime?
  created_at DateTime  @default(now())
  order      order     @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "OrderAddressLink_order_id_fkey")

  @@index([order_id], map: "OrderAddressLink_order_id_idx")
}

model session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model shopconfig {
  id                       Int                               @id @default(autoincrement())
  shop                     String                            @unique(map: "ShopConfig_shop_key")
  app_enabled              Boolean                           @default(true)
  max_retry_limit          Int                               @default(3)
  reminder_interval_amount Int                               @default(1)
  reminder_interval_unit   shopconfig_reminder_interval_unit @default(HOURS)
  created_at               DateTime                          @default(now())
  updated_at               DateTime                          @default(now())
}

model shopnotification {
  id                Int                                @id @default(autoincrement())
  shop              String                             @unique(map: "ShopNotification_shop_key")
  notification_type shopnotification_notification_type @default(EMAIL)
  email_subject     String?
  email_body        String?                            @db.Text
  whatsapp_template String?                            @db.Text
  updated_at        DateTime                           @default(now())
}

model shoptags {
  id                  Int    @id @default(autoincrement())
  shop                String @unique(map: "ShopTags_shop_key")
  incomplete_tag      String @default("address_incomplete")
  awaiting_update_tag String @default("awaiting_customer_update")
  verified_tag        String @default("address_verified")
  updated_tag         String @default("address_updated")
}

model shopemailconfig {
  id         Int      @id @default(autoincrement())
  shop       String   @unique
  config     String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime
}

model device {
  id          Int           @id @default(autoincrement())
  shop        String        @unique
  status      device_status @default(DISCONNECTED)
  sessionId   String        @unique
  created_at  DateTime      @default(now())
  updated_at  DateTime
  device_name String
}

enum shopnotification_notification_type {
  WHATSAPP
  EMAIL
}

enum order_address_status {
  COMPLETE
  INCOMPLETE
  AWAITING_CUSTOMER_RESPONSE
  VERIFIED
}

enum shopconfig_reminder_interval_unit {
  MINUTES
  HOURS
  DAYS
}

enum device_status {
  CONNECTED
  DISCONNECTED
}
